{
  "uid": "recruitment-agent-main",
  "title": "AI Recruitment Agent",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["recruitment", "ai"],
  "panels": [

    { "type": "row", "title": "Tab 1 — Hiring Overview", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 1 },

    {
      "id": 2, "title": "Open JDs", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "targets": [{"expr": "recruitment_jds_created_total - recruitment_jds_closed_total - recruitment_jds_rejected_compliance_total", "legendFormat": "Open JDs", "datasource": "Prometheus"}]
    },
    {
      "id": 3, "title": "Closed JDs", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "blue"}}},
      "targets": [{"expr": "recruitment_jds_closed_total", "legendFormat": "Closed", "datasource": "Prometheus"}]
    },
    {
      "id": 4, "title": "Rejected (Compliance)", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}},
      "targets": [{"expr": "recruitment_jds_rejected_compliance_total", "legendFormat": "Rejected", "datasource": "Prometheus"}]
    },
    {
      "id": 5, "title": "Active Workflows", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "orange"}}},
      "targets": [{"expr": "recruitment_active_workflows", "legendFormat": "Active", "datasource": "Prometheus"}]
    },
    {
      "id": 6, "title": "Candidates Hired", "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "purple"}}},
      "targets": [{"expr": "recruitment_jds_closed_total", "legendFormat": "Hired", "datasource": "Prometheus"}]
    },
    {
      "id": 7, "title": "JD Funnel (30d)", "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {"expr": "recruitment_jds_created_total", "legendFormat": "Created", "datasource": "Prometheus"},
        {"expr": "recruitment_candidate_screened_total", "legendFormat": "Screened", "datasource": "Prometheus"},
        {"expr": "recruitment_candidate_ranked_total", "legendFormat": "Ranked", "datasource": "Prometheus"},
        {"expr": "recruitment_jds_closed_total", "legendFormat": "Closed", "datasource": "Prometheus"}
      ]
    },
    {
      "id": 8, "title": "Candidates Sourced by Source", "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {"expr": "recruitment_candidates_sourced_total", "legendFormat": "{{source}}", "datasource": "Prometheus"}
      ]
    },
    {
      "id": 9, "title": "Sourcing Duration (p50/p95)", "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 13},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(recruitment_sourcing_duration_seconds_bucket[5m]))", "legendFormat": "p50", "datasource": "Prometheus"},
        {"expr": "histogram_quantile(0.95, rate(recruitment_sourcing_duration_seconds_bucket[5m]))", "legendFormat": "p95", "datasource": "Prometheus"}
      ]
    },
    {
      "id": 10, "title": "Time to Shortlist (Screening p50/p95)", "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 13},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(recruitment_screening_duration_seconds_bucket[5m]))", "legendFormat": "p50", "datasource": "Prometheus"},
        {"expr": "histogram_quantile(0.95, rate(recruitment_screening_duration_seconds_bucket[5m]))", "legendFormat": "p95", "datasource": "Prometheus"}
      ]
    },

    { "type": "row", "title": "Tab 2 — Candidate Evaluation", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20}, "id": 20, "collapsed": true, "panels": [] },

    {
      "id": 21, "title": "Candidates Screened (rate)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "targets": [{"expr": "rate(recruitment_candidate_screened_total[5m])", "legendFormat": "screened/s", "datasource": "Prometheus"}]
    },
    {
      "id": 22, "title": "Candidates Ranked (rate)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "targets": [{"expr": "rate(recruitment_candidate_ranked_total[5m])", "legendFormat": "ranked/s", "datasource": "Prometheus"}]
    },
    {
      "id": 23, "title": "Ranking Duration (p50/p95)", "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 29},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(recruitment_ranking_duration_seconds_bucket[5m]))", "legendFormat": "p50", "datasource": "Prometheus"},
        {"expr": "histogram_quantile(0.95, rate(recruitment_ranking_duration_seconds_bucket[5m]))", "legendFormat": "p95", "datasource": "Prometheus"}
      ]
    },

    { "type": "row", "title": "Tab 3 — Agent & Tool Observability", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36}, "id": 40, "collapsed": true, "panels": [] },

    {
      "id": 41, "title": "Agent Calls by Status", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "targets": [
        {"expr": "rate(recruitment_agent_calls_total{status='success'}[5m])", "legendFormat": "{{agent_name}} success", "datasource": "Prometheus"},
        {"expr": "rate(recruitment_agent_calls_total{status='error'}[5m])", "legendFormat": "{{agent_name}} error", "datasource": "Prometheus"}
      ]
    },
    {
      "id": 42, "title": "Tool Calls Total", "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "targets": [{"expr": "recruitment_tool_calls_total", "legendFormat": "{{tool_name}}", "datasource": "Prometheus"}]
    },
    {
      "id": 43, "title": "Tool Failures", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 45},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "targets": [{"expr": "sum(recruitment_tool_failures_total)", "legendFormat": "Tool Failures", "datasource": "Prometheus"}]
    },
    {
      "id": 44, "title": "Tool Latency p95 by Tool", "type": "timeseries",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 45},
      "targets": [{"expr": "histogram_quantile(0.95, rate(recruitment_tool_latency_seconds_bucket[5m]))", "legendFormat": "{{tool_name}} p95", "datasource": "Prometheus"}]
    },
    {
      "id": 45, "title": "LLM Latency by Agent (p95)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 53},
      "targets": [{"expr": "histogram_quantile(0.95, rate(recruitment_llm_latency_seconds_bucket[5m]))", "legendFormat": "{{agent_name}} {{model}}", "datasource": "Prometheus"}]
    },

    { "type": "row", "title": "Tab 4 — LLM & Cost Analytics", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 62}, "id": 60, "collapsed": true, "panels": [] },

    {
      "id": 61, "title": "Daily LLM Cost (USD)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 63},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 50}, {"color": "red", "value": 90}]}}},
      "targets": [{"expr": "recruitment_daily_cost_usd", "legendFormat": "Daily Cost", "datasource": "Prometheus"}]
    },
    {
      "id": 62, "title": "LLM Token Usage by Agent", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 67},
      "targets": [
        {"expr": "rate(recruitment_llm_tokens_total{token_type='input'}[5m])", "legendFormat": "{{agent_name}} input", "datasource": "Prometheus"},
        {"expr": "rate(recruitment_llm_tokens_total{token_type='output'}[5m])", "legendFormat": "{{agent_name}} output", "datasource": "Prometheus"}
      ]
    },
    {
      "id": 63, "title": "LLM Cost by Agent (cumulative)", "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 67},
      "targets": [{"expr": "recruitment_llm_cost_usd_total", "legendFormat": "{{agent_name}} {{model}}", "datasource": "Prometheus"}]
    },
    {
      "id": 64, "title": "LLM Calls Total by Model", "type": "piechart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 75},
      "targets": [{"expr": "recruitment_llm_calls_total", "legendFormat": "{{model}}", "datasource": "Prometheus"}]
    },
    {
      "id": 65, "title": "LLM Error Rate by Agent", "type": "timeseries",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 75},
      "targets": [{"expr": "rate(recruitment_llm_calls_total{status='error'}[5m]) / rate(recruitment_llm_calls_total[5m])", "legendFormat": "{{agent_name}} error rate", "datasource": "Prometheus"}]
    }
  ]
}
